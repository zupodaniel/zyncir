#!/usr/bin/env bash
# Build and/or launch the zyncir menu-bar app.
#
#   ./zyncir            # launch the app (builds first only if the .app is missing)
#   ./zyncir --build    # force a rebuild, then (re)launch
#   ./zyncir --stop     # stop the running app
#
# zyncir must run as the signed .app bundle (via `open`), NOT the bare binary:
# macOS Local Network Privacy only grants LAN access to the signed, bundled app,
# which is what makes wireless adb work. Running the raw executable has no bundle
# identity and would be silently blocked from the local network. Logs go to the
# unified log; view them with:
#   log stream --predicate 'process == "zyncird"' --info
set -euo pipefail
cd "$(dirname "$0")"

APP="mac-app/.build/release/zyncir.app"
PATTERN="zyncir.app/Contents/MacOS/zyncird"   # matches our running app only

running_pids() { pgrep -f "$PATTERN" || true; }

case "${1:-}" in
    --stop)
        pids=$(running_pids)
        if [ -n "$pids" ]; then
            echo "==> Stopping zyncir (pid $pids)"
            pkill -f "$PATTERN" || true
        else
            echo "zyncir is not running."
        fi
        exit 0
        ;;
    --build)
        force_build=1
        ;;
    "")
        force_build=0
        ;;
    *)
        echo "usage: ./zyncir [--build | --stop]" >&2
        exit 2
        ;;
esac

if [ "$force_build" -eq 1 ] || [ ! -d "$APP" ]; then
    echo "==> Building (this may take a moment)…"
    ./build.sh
fi

# Stop any running instance so the freshly built bundle is the one that runs.
if [ -n "$(running_pids)" ]; then
    echo "==> Replacing running instance"
    pkill -f "$PATTERN" || true
    sleep 1
fi

echo "==> Launching zyncir"
open "$APP"
echo "    running: zyncir.app (menu-bar app)"
echo "    logs:    log stream --predicate 'process == \"zyncird\"' --info"
echo "    stop:    ./zyncir --stop"
